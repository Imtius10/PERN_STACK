model User{
  id String @id @default(uuid())
  name String @db.VarChar(255)
  email String @unique
  password String
  activeStatus ActiveStatus @default(Active)
 
  role Role @default(User)

   createdAt DateTime @default(now())
   updatedAt DateTime @updatedAt
  profileId Profile?
  @@map("users")
}

enum ActiveStatus{
    Active
    Blocked
}

enum Role{
    Admin
    User
    Author
}